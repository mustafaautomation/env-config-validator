{
  "name": "env-config-validator",
  "version": "1.0.0",
  "description": "Validate environment configs and .env files against schemas — catch missing vars, type errors, and invalid URLs before deployment",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": { "envcheck": "dist/cli.js" },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "author": "Quvantic <info@quvantic.com> (https://quvantic.com)",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/mustafaautomation/env-config-validator.git" },
  "homepage": "https://github.com/mustafaautomation/env-config-validator#readme",
  "dependencies": { "commander": "^12.1.0" },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=20.0.0" },
  "files": ["dist"]
}
